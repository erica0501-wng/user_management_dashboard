# ===== REQUIRED =====

# Database - REQUIRED for Vercel deployment
# Get from: Vercel Postgres, Supabase, Neon, or Railway
DATABASE_URL="postgresql://user:password@host:port/database?schema=public"

# AWS Isolated Database - OPTIONAL
# Use this when you want this backend to read/write a separate DB (or schema) from another project.
# Can still be on the same PostgreSQL server (different DB name or schema).
# AWS_DATABASE_URL="postgresql://user:password@your-rds-host:5432/another_database"
# USE_AWS_DATABASE="false"
# DB_TARGET="primary"  # set to "aws" to force AWS_DATABASE_URL
# AWS_DB_ENFORCE_ISOLATION="true"
# AWS_DB_SCHEMA="user_management_dashboard_aws"

# JWT Secret - REQUIRED for authentication
# Generate a random string (at least 32 characters)
JWT_SECRET="your-super-secret-jwt-key-change-this-to-random-string"

# ===== OPTIONAL =====

# Google OAuth - OPTIONAL (only if you want Google login)
# GOOGLE_CLIENT_ID="your-google-client-id"

# Email Notifications - OPTIONAL (for email alerts)
# SMTP_HOST="smtp.gmail.com"
# SMTP_PORT="587"
# SMTP_SECURE="false"
# SMTP_USER="your-email@gmail.com"
# SMTP_PASS="your-app-specific-password"
# SMTP_FROM="Polymarket Alerts <your-email@gmail.com>"

# Node Environment - Recommended for production
NODE_ENV="production"

# Polymarket Archive Ingestion - OPTIONAL but recommended for Archive Health pages
# Enables market snapshot collection when running a persistent backend process locally.
# Note: Vercel serverless does not keep background intervals alive; use CRON_SECRET + vercel.json cron.
# ENABLE_POLYMARKET_ARCHIVER="true"
# POLYMARKET_ARCHIVE_INTERVAL_MS="300000"
# POLYMARKET_ARCHIVE_MARKET_LIMIT="20"
#
# Priority groups: tag-slug-driven sets that are always included in the snapshot
# (covers both currently-open and recently-closed/past markets per group).
# Defaults: Elon Tweets, Economic Policy, NBA, Movies.
# Override with a JSON array; each entry needs `slug` and optional `keywords` fallback.
# POLYMARKET_ARCHIVE_PRIORITY_GROUPS='[{"name":"Elon Tweets","slug":"elon-tweets","keywords":["elon","musk"]},{"name":"NBA","slug":"nba","keywords":["nba"]}]'
# POLYMARKET_ARCHIVE_PRIORITY_PER_GROUP_LIMIT="30"
# POLYMARKET_ARCHIVE_PRIORITY_CLOSED_PER_GROUP_LIMIT="20"
#
# Deprioritized categories: still archived, but pushed to the back of the queue
# and capped to a fraction of the per-run cap so priority groups always fit.
# POLYMARKET_ARCHIVE_DEPRIORITIZE_CATEGORIES="crypto,politics"
# POLYMARKET_ARCHIVE_DEPRIORITIZED_SHARE="0.25"
# POLYMARKET_ARCHIVE_MAX_MARKETS_PER_RUN="600"

# Vercel Cron Security - REQUIRED when using backend/vercel.json cron
# Set this in Vercel project env vars; Vercel cron will send Authorization: Bearer <CRON_SECRET>
# CRON_SECRET="replace-with-long-random-string"
