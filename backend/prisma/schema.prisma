generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int                  @id @default(autoincrement())
  username            String               @unique
  email               String               @unique
  age                 Int?
  createdAt           DateTime             @default(now())
  role                Role                 @default(User)
  status              Status               @default(Active)
  joinedDate          DateTime             @default(now())
  lastActive          DateTime             @default(now())
  password            String?
  provider            String               @default("local")
  providerId          String?
  gender              Gender?
  orders              Order[]
  accountBalance      AccountBalance?
  transactions        Transaction[]
  watchlists          Watchlist[]
  sharedWatchlists    SharedWatchlist[]    @relation("OwnedSharedWatchlists")
  watchlistComments   WatchlistComment[]   @relation("UserComments")
  watchlistLikes      WatchlistLike[]      @relation("UserLikes")
  polymarketPositions PolymarketPosition[] @relation("PolymarketPositions")
  alerts              Alert[]              @relation("UserAlerts")
  autoTraders         AutoTrader[]         @relation("UserAutoTraders")
  notificationSettings NotificationSettings?
}

model Order {
  id        Int            @id @default(autoincrement())
  userId    Int
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol    String
  name      String?
  direction OrderDirection
  price     Float
  quantity  Int
  orderType String         @default("Limit")
  session   String?
  status    OrderStatus    @default(Pending)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model AccountBalance {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  availableCash Float    @default(100000)
  totalInvested Float    @default(0)
  updatedAt     DateTime @updatedAt
}

model Transaction {
  id            Int             @id @default(autoincrement())
  userId        Int
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          TransactionType
  amount        Float
  paymentMethod String?
  createdAt     DateTime        @default(now())
}

enum Role {
  Admin
  User
}

enum Status {
  Active
  Inactive
  Banned
}

enum Gender {
  Male
  Female
}

enum OrderDirection {
  Buy
  Sell
}

enum OrderStatus {
  Pending
  Filled
  Cancelled
}

enum TransactionType {
  TopUp
  Withdraw
}

model Watchlist {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol    String
  createdAt DateTime @default(now())

  @@unique([userId, symbol])
}

// Social features for sharing watchlists
model SharedWatchlist {
  id          Int                 @id @default(autoincrement())
  ownerId     Int
  owner       User                @relation("OwnedSharedWatchlists", fields: [ownerId], references: [id], onDelete: Cascade)
  title       String
  description String?
  isPublic    Boolean             @default(true)
  symbols     String[]            // Array of stock symbols
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  comments    WatchlistComment[]
  likes       WatchlistLike[]
}

model WatchlistComment {
  id                Int              @id @default(autoincrement())
  sharedWatchlistId Int
  sharedWatchlist   SharedWatchlist  @relation(fields: [sharedWatchlistId], references: [id], onDelete: Cascade)
  userId            Int
  user              User             @relation("UserComments", fields: [userId], references: [id], onDelete: Cascade)
  content           String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model WatchlistLike {
  id                Int              @id @default(autoincrement())
  sharedWatchlistId Int
  sharedWatchlist   SharedWatchlist  @relation(fields: [sharedWatchlistId], references: [id], onDelete: Cascade)
  userId            Int
  user              User             @relation("UserLikes", fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime         @default(now())

  @@unique([sharedWatchlistId, userId])
}

// Polymarket prediction market positions
model PolymarketPosition {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation("PolymarketPositions", fields: [userId], references: [id], onDelete: Cascade)
  marketId    String   // Polymarket market ID
  question    String   // Market question
  outcome     String   // Which outcome was bet on (Yes/No or specific option)
  shares      Float    // Number of shares purchased
  avgPrice    Float    // Average price per share
  totalCost   Float    // Total amount invested
  currentPrice Float?  // Current market price (updated periodically)
  status      PositionStatus @default(Open)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum PositionStatus {
  Open
  Closed
  Resolved
}

// Alerts for Polymarket markets
model Alert {
  id          Int        @id @default(autoincrement())
  userId      Int
  user        User       @relation("UserAlerts", fields: [userId], references: [id], onDelete: Cascade)
  marketId    String     // Polymarket market ID
  question    String     // Market question for reference
  outcome     String     // Which outcome to monitor (Yes/No or specific option)
  alertType   AlertType  // Type of alert (Price, OrderBook)
  targetPrice Float?     // Target price for price alerts (0-1)
  condition   AlertCondition? // Above or Below for price alerts
  orderBookThreshold Float? // Minimum order book size to trigger (for order book alerts)
  notificationChannels String[] @default([]) // Channels to notify: email, telegram, discord
  isActive    Boolean    @default(true)
  isTriggered Boolean    @default(false)
  triggeredAt DateTime?  // When the alert was triggered
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum AlertType {
  Price          // Price reaches target
  OrderBook      // Large order book appears
}

enum AlertCondition {
  Above    // Price goes above target
  Below    // Price goes below target
}

// Notification settings for each user
model NotificationSettings {
  id                     Int      @id @default(autoincrement())
  userId                 Int      @unique
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emailEnabled           Boolean  @default(true)
  discordEnabled         Boolean  @default(false)
  discordWebhookUrl      String?  // Discord webhook URL
  discordChannelName     String?  // Discord channel name for reference
  defaultChannels        String[] @default(["email"]) // Default channels for new alerts
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

// Auto-trader rules for automated trading
model AutoTrader {
  id                Int                @id @default(autoincrement())
  userId            Int
  user              User               @relation("UserAutoTraders", fields: [userId], references: [id], onDelete: Cascade)
  marketId          String             // Polymarket market ID or stock symbol
  question          String             // Market question/description
  outcome           String?            // Which outcome to trade (for Polymarket)
  strategyType      StrategyType       // Type of trading strategy
  triggerCondition  TriggerCondition   // Condition to trigger trade
  targetPrice       Float?             // Target price for price-based strategies
  movingAvgPeriod   Int?               // Period for moving average (e.g., 7 days)
  action            TradeAction        // Buy or Sell when triggered
  quantity          Float              // Number of shares to trade
  maxExecutions     Int                @default(1) // Maximum times this rule can execute
  executionCount    Int                @default(0) // Times this rule has executed
  isActive          Boolean            @default(true)
  notifyOnExecution Boolean            @default(true) // Send notification when trade executes
  notificationChannels String[]        @default(["email"]) // email, discord
  lastCheckedAt     DateTime?          // Last time the rule was evaluated
  lastExecutedAt    DateTime?          // Last time trade was executed
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt
}

enum StrategyType {
  PriceTarget       // Execute when price reaches target
  MovingAverage     // Execute when price crosses moving average
  PriceChange       // Execute when price changes by percentage
}

enum TriggerCondition {
  Above             // Price goes above target
  Below             // Price goes below target
  CrossAbove        // Price crosses above moving average
  CrossBelow        // Price crosses below moving average
  Increase          // Price increases by percentage
  Decrease          // Price decreases by percentage
}

enum TradeAction {
  Buy
  Sell
}

model PolymarketMarketSnapshot {
  id            Int      @id @default(autoincrement())
  marketId      String
  question      String
  category      String?
  closed        Boolean  @default(false)
  closedTime    DateTime?
  eventStartAt  DateTime?
  eventEndAt    DateTime?
  sourceCreatedAt DateTime?
  outcomes      Json?
  outcomePrices Json?
  tokenIds      Json?
  volume        Float?
  liquidity     Float?
  endDate       DateTime?
  intervalStart DateTime
  createdAt     DateTime @default(now())
  orderBooks    PolymarketOrderBookSnapshot[] @relation("MarketToOrderBooks")

  @@unique([marketId, intervalStart])
  @@index([intervalStart])
  @@index([eventStartAt])
  @@index([eventEndAt])
  @@index([closedTime])
}

model PolymarketOrderBookSnapshot {
  id            Int      @id @default(autoincrement())
  marketId      String
  tokenId       String
  outcome       String?
  bidVolume     Float    @default(0)
  askVolume     Float    @default(0)
  totalVolume   Float    @default(0)
  bestBid       Float?
  bestAsk       Float?
  spread        Float?
  spreadPercent Float?
  bidDepth      Int      @default(0)
  askDepth      Int      @default(0)
  bids          Json?
  asks          Json?
  intervalStart DateTime
  createdAt     DateTime @default(now())
  market        PolymarketMarketSnapshot? @relation("MarketToOrderBooks", fields: [marketId, intervalStart], references: [marketId, intervalStart], onDelete: NoAction, onUpdate: NoAction)

  @@unique([tokenId, intervalStart])
  @@index([marketId, intervalStart])
  @@index([intervalStart])
}

model PolymarketDataQualityReport {
  id                     Int      @id @default(autoincrement())
  windowHours            Int
  intervalMinutes        Int
  expectedIntervals      Int
  distinctMarkets        Int      @default(0)
  distinctTokens         Int      @default(0)
  totalMarketSnapshots   Int      @default(0)
  totalOrderBookSnapshots Int     @default(0)
  marketCoveragePct      Float    @default(0)
  orderBookCoveragePct   Float    @default(0)
  staleMinutes           Int?
  notes                  String?
  generatedAt            DateTime @default(now())

  @@index([generatedAt])
}

// Market groups for organizing backtest data by category
model MarketGroup {
  id          Int      @id @default(autoincrement())
  name        String   @unique  // e.g., "Elon Tweets", "Mr Beast Videos"
  description String?
  pattern     String   // Regex pattern to match questions
  markets     String[] // Array of matched marketIds
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  
  backtests   Backtest[] // Associated backtest results
}

// Backtest results tracking
model Backtest {
  id              Int      @id @default(autoincrement())
  groupId         Int
  group           MarketGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  marketId        String?  // Polymarket market id this backtest was run against (1 backtest = 1 market). Nullable for legacy rows only.
  marketQuestion  String?  // Snapshot of the market question at backtest time, for display in dashboards.
  strategyName    String   // e.g., "momentum_strategy", "mean_reversion"
  startTime       DateTime
  endTime         DateTime
  initialCapital  Float
  finalValue      Float
  pnl             Float    // Profit/Loss
  roi             Float    // Return on Investment %
  winRate         Float    // Win rate %
  totalTrades     Int
  winningTrades   Int
  losingTrades    Int
  maxDrawdown     Float    // Maximum drawdown %
  params          Json     // Strategy parameters used
  tradeHistory    Json?    // Detailed trade log
  createdAt       DateTime @default(now())

  @@index([groupId])
  @@index([marketId])
  @@index([createdAt])
}
