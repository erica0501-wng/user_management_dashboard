generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                  Int                  @id @default(autoincrement())
  username            String               @unique
  email               String               @unique
  age                 Int?
  createdAt           DateTime             @default(now())
  role                Role                 @default(User)
  status              Status               @default(Active)
  joinedDate          DateTime             @default(now())
  lastActive          DateTime             @default(now())
  password            String?
  provider            String               @default("local")
  providerId          String?
  gender              Gender?
  orders              Order[]
  accountBalance      AccountBalance?
  transactions        Transaction[]
  watchlists          Watchlist[]
  sharedWatchlists    SharedWatchlist[]    @relation("OwnedSharedWatchlists")
  watchlistComments   WatchlistComment[]   @relation("UserComments")
  watchlistLikes      WatchlistLike[]      @relation("UserLikes")
  polymarketPositions PolymarketPosition[] @relation("PolymarketPositions")
  alerts              Alert[]              @relation("UserAlerts")
}

model Order {
  id        Int            @id @default(autoincrement())
  userId    Int
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol    String
  name      String?
  direction OrderDirection
  price     Float
  quantity  Int
  orderType String         @default("Limit")
  session   String?
  status    OrderStatus    @default(Pending)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
}

model AccountBalance {
  id            Int      @id @default(autoincrement())
  userId        Int      @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  availableCash Float    @default(100000)
  totalInvested Float    @default(0)
  updatedAt     DateTime @updatedAt
}

model Transaction {
  id            Int             @id @default(autoincrement())
  userId        Int
  user          User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          TransactionType
  amount        Float
  paymentMethod String?
  createdAt     DateTime        @default(now())
}

enum Role {
  Admin
  User
}

enum Status {
  Active
  Inactive
  Banned
}

enum Gender {
  Male
  Female
}

enum OrderDirection {
  Buy
  Sell
}

enum OrderStatus {
  Pending
  Filled
  Cancelled
}

enum TransactionType {
  TopUp
  Withdraw
}

model Watchlist {
  id        Int      @id @default(autoincrement())
  userId    Int
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  symbol    String
  createdAt DateTime @default(now())

  @@unique([userId, symbol])
}

// Social features for sharing watchlists
model SharedWatchlist {
  id          Int                 @id @default(autoincrement())
  ownerId     Int
  owner       User                @relation("OwnedSharedWatchlists", fields: [ownerId], references: [id], onDelete: Cascade)
  title       String
  description String?
  isPublic    Boolean             @default(true)
  symbols     String[]            // Array of stock symbols
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  comments    WatchlistComment[]
  likes       WatchlistLike[]
}

model WatchlistComment {
  id                Int              @id @default(autoincrement())
  sharedWatchlistId Int
  sharedWatchlist   SharedWatchlist  @relation(fields: [sharedWatchlistId], references: [id], onDelete: Cascade)
  userId            Int
  user              User             @relation("UserComments", fields: [userId], references: [id], onDelete: Cascade)
  content           String
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
}

model WatchlistLike {
  id                Int              @id @default(autoincrement())
  sharedWatchlistId Int
  sharedWatchlist   SharedWatchlist  @relation(fields: [sharedWatchlistId], references: [id], onDelete: Cascade)
  userId            Int
  user              User             @relation("UserLikes", fields: [userId], references: [id], onDelete: Cascade)
  createdAt         DateTime         @default(now())

  @@unique([sharedWatchlistId, userId])
}

// Polymarket prediction market positions
model PolymarketPosition {
  id          Int      @id @default(autoincrement())
  userId      Int
  user        User     @relation("PolymarketPositions", fields: [userId], references: [id], onDelete: Cascade)
  marketId    String   // Polymarket market ID
  question    String   // Market question
  outcome     String   // Which outcome was bet on (Yes/No or specific option)
  shares      Float    // Number of shares purchased
  avgPrice    Float    // Average price per share
  totalCost   Float    // Total amount invested
  currentPrice Float?  // Current market price (updated periodically)
  status      PositionStatus @default(Open)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum PositionStatus {
  Open
  Closed
  Resolved
}

// Alerts for Polymarket markets
model Alert {
  id          Int        @id @default(autoincrement())
  userId      Int
  user        User       @relation("UserAlerts", fields: [userId], references: [id], onDelete: Cascade)
  marketId    String     // Polymarket market ID
  question    String     // Market question for reference
  outcome     String     // Which outcome to monitor (Yes/No or specific option)
  alertType   AlertType  // Type of alert (Price, OrderBook)
  targetPrice Float?     // Target price for price alerts (0-1)
  condition   AlertCondition? // Above or Below for price alerts
  orderBookThreshold Float? // Minimum order book size to trigger (for order book alerts)
  isActive    Boolean    @default(true)
  isTriggered Boolean    @default(false)
  triggeredAt DateTime?  // When the alert was triggered
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum AlertType {
  Price          // Price reaches target
  OrderBook      // Large order book appears
}

enum AlertCondition {
  Above    // Price goes above target
  Below    // Price goes below target
}
