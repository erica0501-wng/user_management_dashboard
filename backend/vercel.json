{
  "version": 2,
  "functions": {
    "api/index.js": {
      "maxDuration": 300
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/api/index.js"
    }
  ],
  "crons": [
    {
      "path": "/polymarket/archive/ingest/run",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/polymarket/backtest/auto-run?maxRuns=10",
      "schedule": "0 13 * * *"
    },
    {
      "path": "/polymarket/backtest/auto-run?maxRuns=12&groups=Elon%20Tweets,Economic%20Policy,NBA,Movies",
      "schedule": "30 13 * * *"
    }
  ]
}